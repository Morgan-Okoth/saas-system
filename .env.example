.APP_NAME=SaaS School System
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://saas.example.com

# Database - Using Supabase/Neon (Postgres)
DB_CONNECTION=pgsql
DB_HOST=db.supabase.co
DB_PORT=5432
DB_DATABASE=saas_production
DB_USERNAME=postgres
DB_PASSWORD=

# Redis (Self-hosted on VPS)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Cloudinary (File Storage)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=saas_uploads

# Mail
MAIL_MAILER=resend
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=notifications@saas-example.com
MAIL_FROM_NAME="SaaS School System"

# Services
RESEND_KEY=re_123...
STRIPE_KEY=pk_live_...
STRIPE_SECRET=sk_live_...
M-PESA_CONSUMER_KEY=
M-PESA_CONSUMER_SECRET=
M-PESA_PASSKEY=

# Security
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict
CSRF_TRUSTED_PROXIES=*
TRUSTED_PROXIES=*

# Tenancy
TENANT_DOMAIN_STRICT=false
TENANT_DATABASE_PREFIX=tenant_
